# Environment Variables for Blockchain Escrow System
# Copy this file to .env and fill in your actual values

# Ethereum Private Key (from MetaMask or your wallet)
# WARNING: Never commit .env file! Always keep private keys secure!
SEPOLIA_PRIVATE_KEY=your_sepolia_wallet_private_key_here

# Infura/Alchemy RPC URL (optional, if using a service)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key_here

# Etherscan API Key for contract verification (optional)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Contract address (to be filled after deployment)
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
